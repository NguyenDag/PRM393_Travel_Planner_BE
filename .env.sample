# --- DATABASE CONFIG (Used for Postgres container) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=PRM393_Travel_Planner

# --- CONNECTION STRING (Used for Backend) ---
# Note: 'db' is the service name of Postgres in docker-compose.yml
# For local development without Docker, use 'localhost' instead of 'db'
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=PRM393_Travel_Planner;Username=postgres;Password=your_secure_password_here

# Alternatively, you can use these for Production/Railway environments
# DATABASE_URL=postgres://user:password@host:port/database
# MY_CUSTOM_DB_URL=...

# --- JWT CONFIG ---
# Generate a long, random string for the secret (min 32 characters)
Jwt__Secret=your_very_long_and_secure_jwt_secret_here_at_least_32_chars
Jwt__Issuer=TravelPlannerAPI
Jwt__Audience=TravelPlannerClient
Jwt__AccessTokenExpiryMinutes=60
Jwt__RefreshTokenExpiryDays=30

# --- CLOUDINARY CONFIG ---
Cloudinary__CloudName=your_cloudinary_cloud_name
Cloudinary__ApiKey=your_cloudinary_api_key
Cloudinary__ApiSecret=your_cloudinary_api_secret

# --- EMAIL CONFIG (SMTP) ---
Email__SmtpHost=smtp.gmail.com
Email__SmtpPort=587
Email__SmtpUser=your_email@gmail.com
Email__SmtpPass=your_app_password_here
Email__FromName=Du Xuan Planner
Email__FromAddress=your_email@gmail.com

# --- ASP.NET CORE ENV ---
ASPNETCORE_ENVIRONMENT=Development
# Optional: Allowed origins for CORS (comma-separated or JSON array)
# AllowedOrigins=["http://localhost:3000"]
