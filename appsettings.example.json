{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Jwt": {
        "Secret": "REPLACE_WITH_YOUR_JWT_SECRET_MIN_32_CHARS",
        "Issuer": "TravelPlannerAPI",
        "Audience": "TravelPlannerClient",
        "AccessTokenExpiryMinutes": "60",
        "RefreshTokenExpiryDays": "30"
    },
    "ConnectionStrings": {
        "DefaultConnection": "Host=YOUR_HOST;Port=YOUR_PORT;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASS"
    },
    "Cloudinary": {
        "CloudName": "YOUR_CLOUD_NAME",
        "ApiKey": "YOUR_API_KEY",
        "ApiSecret": "YOUR_API_SECRET"
    },
    "Email": {
        "SmtpHost": "smtp.gmail.com",
        "SmtpPort": "587",
        "SmtpUser": "YOUR_EMAIL@gmail.com",
        "SmtpPass": "YOUR_APP_PASSWORD",
        "FromName": "Du Xuan Planner",
        "FromAddress": "YOUR_EMAIL@gmail.com"
    }
}