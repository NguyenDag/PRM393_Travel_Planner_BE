# OpenAI API Key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key_here"

# Pexels API Key - get one at https://www.pexels.com/api/
PEXELS_API_KEY="your_pexels_api_key_here"

HOST="0.0.0.0"
PORT=8000
ENVIRONMENT="development"

# Shared secret between ASP.NET Core backend and this AI service
INTERNAL_SECRET=your_shared_secret_here

# Redis (optional, for caching — leave blank to disable)
REDIS_URL=redis://localhost:6379

# Allowed origins for CORS (comma-separated or JSON array)
ALLOWED_ORIGINS='["http://localhost:3000", "http://localhost:5000"]'

# App environment: development | production
APP_ENV=development
